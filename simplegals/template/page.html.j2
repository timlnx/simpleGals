{# simplegals/template/page.html.j2 #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}{% if not is_all_page and total_pages > 1 %} — Page {{ current_page }} of {{ total_pages }}{% endif %}</title>
  <link rel="stylesheet" href="{{ css_path }}">
  <style>:root { --columns: {{ columns }}; }</style>
</head>
<body>
  <div class="key-legend"><kbd>←</kbd> prev · <kbd>→</kbd> next · <kbd>u</kbd> up</div>
  <header>
    {% if is_all_page %}
    <h1><a href="index.html" class="back-link">{{ title }}<span class="back-hint">← back to page listing</span></a></h1>
    {% else %}
    <h1>{{ title }}</h1>
    {% endif %}
    {% if description %}<p>{{ description }}</p>{% endif %}
  </header>

  {% if not is_all_page %}
  <nav class="pagination">
    {% if current_page > 1 %}
      <a href="{% if current_page == 2 %}index.html{% else %}page-{{ current_page - 1 }}.html{% endif %}">← Prev</a>
    {% endif %}
    {% for n in range(1, total_pages + 1) %}
      {% if n == current_page %}
        <span class="current">{{ n }}</span>
      {% else %}
        <a href="{% if n == 1 %}index.html{% else %}page-{{ n }}.html{% endif %}">{{ n }}</a>
      {% endif %}
    {% endfor %}
    {% if current_page < total_pages %}
      <a href="page-{{ current_page + 1 }}.html">Next →</a>
    {% endif %}
    <a href="all.html" class="all-link">View all</a>
  </nav>
  {% endif %}

  <div class="gallery-grid">
    {% for image in images %}
    <div class="gallery-item" id="{{ image.filename }}">
      <a href="{{ image.item_page }}?from={% if is_all_page %}all.html{% elif current_page == 1 %}index.html{% else %}page-{{ current_page }}.html{% endif %}&amp;anchor={{ image.filename }}">
        <img src="{{ image.thumb_path }}" alt="{{ image.alt or image.filename }}">
      </a>
      {% if image.caption %}
      <div class="caption">{{ image.caption }}</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>

  <footer>
    {% if copyright %}{{ copyright }}{% endif %}
    <p class="generated-by"><a href="https://github.com/timlnx/simpleGals" target="_blank" rel="noopener noreferrer">generated with simpleGals</a></p>
  </footer>
  {% if is_all_page %}
  <script>
    document.addEventListener('keydown', function(e) {
      if (e.key === 'u' || e.key === 'U') window.location.href = 'index.html';
    });
  </script>
  {% else %}
  <script>
    const prev = {{ ('index.html' if current_page == 2 else 'page-' ~ (current_page - 1) ~ '.html') | tojson if current_page > 1 else 'null' }};
    const next = {{ ('page-' ~ (current_page + 1) ~ '.html') | tojson if current_page < total_pages else 'null' }};
    document.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft' && prev) window.location.href = prev;
      if (e.key === 'ArrowRight' && next) window.location.href = next;
    });
  </script>
  {% endif %}
</body>
</html>
