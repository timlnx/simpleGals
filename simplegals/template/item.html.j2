{# simplegals/template/item.html.j2 #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — {{ image.filename }}</title>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ title }}">
  <meta property="og:title" content="{{ image.caption or image.filename }}">
  {% if image.caption or description %}<meta property="og:description" content="{{ image.caption or description }}">{% endif %}
  {% if site_url %}
  <meta property="og:image" content="{{ site_url }}/{{ image.thumb_path }}">
  <meta property="og:url" content="{{ site_url }}/{{ image.item_page }}">
  {% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ image.caption or image.filename }}">
  {% if image.caption or description %}<meta name="twitter:description" content="{{ image.caption or description }}">{% endif %}
  {% if site_url %}<meta name="twitter:image" content="{{ site_url }}/{{ image.thumb_path }}">{% endif %}
  {% if author %}<meta name="author" content="{{ author }}">{% endif %}
  <link rel="stylesheet" href="{{ css_path }}">
</head>
<body>
  <div class="item-page">
    <header>
      <h1><a href="index.html" style="color:inherit;text-decoration:none;">{{ title }}</a></h1>
    </header>

    <a href="{{ image.output_path }}">
      <img src="{{ image.display_path }}" alt="{{ image.alt or image.filename }}">
    </a>

    <div class="item-meta">
      <span>{{ image.filename }}</span>
      <span>{{ image.date }}</span>
      <span>{{ image.size }}</span>
      <span><a href="{{ image.output_path }}" download>💾</a></span>
    </div>

    {% if image.caption %}<p style="margin-bottom:1rem;color:#ccc;">{{ image.caption }}</p>{% endif %}

    <nav class="item-nav">
      {% if prev_image %}
        <a href="{{ prev_image.item_page }}">← {{ prev_image.filename }}</a>
      {% else %}
        <span></span>
      {% endif %}
      {% if next_image %}
        <a href="{{ next_image.item_page }}">{{ next_image.filename }} →</a>
      {% endif %}
    </nav>

    <footer>
      {% if copyright %}{{ copyright }}{% endif %}
      <p class="generated-by"><a href="https://github.com/timlnx/simpleGals" target="_blank" rel="noopener noreferrer">generated with simpleGals</a></p>
    </footer>
  </div>
  <div class="key-legend"><kbd>←</kbd> prev · <kbd>→</kbd> next · <kbd>u</kbd> up</div>
  <script>
    const prev = {{ prev_image.item_page | tojson if prev_image else 'null' }};
    const next = {{ next_image.item_page | tojson if next_image else 'null' }};
    const thisFile = {{ image.filename | tojson }};
    const fromPage = new URLSearchParams(window.location.search).get('from');

    if (fromPage) {
      document.querySelectorAll('nav.item-nav a').forEach(function(a) {
        a.href = a.getAttribute('href') + '?from=' + fromPage;
      });
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft' && prev) window.location.href = prev + (fromPage ? '?from=' + fromPage : '');
      if (e.key === 'ArrowRight' && next) window.location.href = next + (fromPage ? '?from=' + fromPage : '');
      if (e.key === 'u' || e.key === 'U') {
        window.location.href = fromPage ? fromPage + '#' + thisFile : 'index.html';
      }
    });
  </script>
</body>
</html>
